{
  "name": "xt-database-driver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply xt-data --local",
    "db:migrate:remote": "wrangler d1 migrations apply xt-data --remote",
    "db:execute:local": "wrangler d1 execute xt-data --local",
    "db:execute:remote": "wrangler d1 execute xt-data --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20260620.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.22.0"
  }
}
